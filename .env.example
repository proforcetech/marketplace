# =============================================================================
# Marketplace - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the .env file to version control.
# =============================================================================

# --- General ---
NODE_ENV=development
APP_NAME=Marketplace
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
API_PORT=3001
WEB_PORT=3000

# --- Database (PostgreSQL + PostGIS) ---
DATABASE_URL=postgresql://marketplace:marketplace_dev@localhost:5432/marketplace?schema=public
DATABASE_DIRECT_URL=postgresql://marketplace:marketplace_dev@localhost:5432/marketplace?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Authentication ---
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# --- Twilio (Phone OTP) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_IDENTITY_VERIFICATION_TEMPLATE=

# --- AWS S3 / MinIO (Object Storage) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=marketplace-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_USE_PATH_STYLE=true

# CDN URL for serving media (CloudFront or direct S3/MinIO URL for dev)
CDN_URL=http://localhost:9000/marketplace-media

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk....

# --- Email (SMTP / Mailpit for dev) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@marketplace.local

# --- Sentry (Error Tracking) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Rate Limiting ---
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# --- Logging ---
LOG_LEVEL=debug
LOG_FORMAT=pretty

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
