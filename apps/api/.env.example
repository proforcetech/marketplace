# =============================================================================
# Marketplace API - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit the .env file to version control.
# =============================================================================

# Database
DATABASE_URL=postgresql://marketplace:marketplace_dev@localhost:5432/marketplace?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (RS256 asymmetric — generate with: openssl genrsa 2048 | tee private.pem | openssl rsa -pubout > public.pem)
# Store the PEM content as a single line with \n replacing actual newlines
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# App
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Storage (MinIO locally, S3 in production)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=marketplace-media
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true
CDN_URL=http://localhost:9000/marketplace-media

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BUMP=price_...
STRIPE_PRICE_FEATURED=price_...
STRIPE_PRICE_SPOTLIGHT=price_...

# Email (SMTP -- Mailpit for local development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@marketplace.local

# Phone OTP (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# Geocoding
GEOCODING_API_KEY=

# Risk scoring
RISK_SCORE_AUTO_HOLD_THRESHOLD=70
RISK_SCORE_AUTO_REJECT_THRESHOLD=90
