# =============================================================================
# Marketplace Web - Environment Configuration
# =============================================================================
# Copy this file to .env.local and update values for your environment.
# NEVER commit .env.local to version control.
# =============================================================================

# API
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3000

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Maps / Geocoding
NEXT_PUBLIC_MAPS_API_KEY=
# Mapbox — obtain from https://account.mapbox.com/access-tokens/
# Restrict to your production domain before launch
NEXT_PUBLIC_MAPBOX_TOKEN=pk.ey...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Marketplace
